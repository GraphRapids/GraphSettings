{
  "name": "graph-settings",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e:install": "npx playwright install --with-deps chromium",
    "test:e2e": "npx playwright test",
    "test:integration": "node --test tests/integration/*.test.mjs",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "openapi:download": "curl -o openapi/openapi.json http://127.0.0.1:8000/openapi.json",
    "openapi:generate": "npx openapi-typescript openapi/openapi.json -o src/api/generated/schema.ts",
    "openapi:refresh": "npm run openapi:download && npm run openapi:generate"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "openapi-fetch": "^0.13.5",
    "ra-data-simple-rest": "^5.5.2",
    "react": "^19.0.0",
    "react-admin": "^5.5.2",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.6",
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.51.0",
    "@storybook/addon-essentials": "^8.6.4",
    "@storybook/addon-interactions": "^8.6.4",
    "@storybook/react": "^8.6.4",
    "@storybook/react-vite": "^8.6.4",
    "@storybook/test": "^8.6.4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jsdom": "^26.0.0",
    "openapi-typescript": "^7.6.1",
    "storybook": "^8.6.4",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0",
    "vitest": "^3.0.7"
  }
}
